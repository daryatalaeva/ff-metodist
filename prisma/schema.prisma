datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Generation {
  id                String   @id @default(uuid())
  userId            String?
  featureType       String
  subject           String?
  grade             Int?
  topic             String?
  examFormat        String?
  questionTypes     String[]
  questionCount     Int?
  textbookName      String?
  textbookFileUrl   String?
  extraInstructions String?
  promptTokens      Int?
  completionTokens  Int?
  resultJson        Json?
  resultText        String?
  feedback          String?
  wasCopied         Boolean  @default(false)
  wasDownloaded     Boolean  @default(false)
  wasRegenerated    Boolean  @default(false)
  wasPresented      Boolean? @default(false)
  createdAt         DateTime @default(now())

  // ── Lesson plan fields ──────────────────────────────────────────
  // lesson_type: тип урока по ФГОС
  //   'new_knowledge' | 'reflection' | 'methodology'
  //   'developmental_control' | 'combined'
  lessonType        String?
  // lesson_form: форма проведения
  //   'traditional' | 'practical' | 'seminar' | 'game'
  //   'project' | 'lecture' | 'excursion' | 'test_lesson'
  lessonForm        String?
  // lesson_duration: продолжительность в минутах (40 | 45 | 90)
  lessonDuration    Int?
  // lesson_position: место в теме ('intro' | 'main' | 'final')
  lessonPosition    String?
  // learning_goals: опциональные цели от учителя
  learningGoals     String?
}

model SubscriptionRequest {
  id        String   @id @default(uuid())
  email     String
  createdAt DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
